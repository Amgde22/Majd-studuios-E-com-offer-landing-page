---
// This section remains unchanged as it handles data fetching and internationalization.
import navData from "@data/navData";
import { Icon } from "astro-icon/components";
import { getLocalePath, t  ,getLocale} from "i18n:astro";

const bannerTitle = t("home:banner.title", { date: t("home:banner.date") });
const bannerSubheading = t("home:banner.subtitle");
---

<!-- Templates for cloning stars and wind lines -->
<div class="templates">
    <svg class="star-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/></svg>
    <svg class="line-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><g fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"><path d="M1.5 11A1.5 1.5 0 0 1 3 9.5h15a1.5 1.5 0 0 1 0 3H3A1.5 1.5 0 0 1 1.5 11" opacity="0.2"/><path d="M.5 10a.5.5 0 0 1 .5-.5h18a.5.5 0 0 1 0 1H1a.5.5 0 0 1-.5-.5"/></g></svg>
</div>

<a id="banner" href="https://wa.me/213556640229" target="_blank" class="cs-hide top-banner lead-magnet-banner spaceship-animation-container">
    <div class="top-banner-grid">
      <p class="magnet-title">{bannerTitle}</p>
      <p class="magnet-information">{bannerSubheading}</p>
      <Icon class={`magnet-icon`}  name="play" />
    </div>
</a>

<script>

window.addEventListener('load', ()=>{
    //-- ==================================================================
    //-- BANNER UNDER HEADER SCRIPT
    //-- ==================================================================
    const bannerElement = document.querySelector('a.top-banner.lead-magnet-banner');
    const header = document.getElementById("cs-navigation");

    if (bannerElement && header) {
      const height = header.getBoundingClientRect().height;
      bannerElement.style.top = height  + "px"
    }

    //-- ==================================================================
    //-- SHOW ON SCROLL SCRIPT
    //-- ==================================================================


    const hero = document.getElementById("hero");
    const scrollValue = hero?.getBoundingClientRect().height  || 850 ;
    document.addEventListener("scroll", () => {
        const banner = document.getElementById("banner");
        if (banner) {
        if (window.scrollY > scrollValue - 100) {
            // Adjust 200 to your desired scroll amount
            banner.classList.remove("cs-hide");
        } else {
            banner.classList.add("cs-hide");
        }
        }
  });

    






    //-- ==================================================================
    //-- SPACESHIP HOVER ANIMATION SCRIPT
    //-- ==================================================================
    
    //-- CONFIGURATION & VARIABLES
    // const direction = document.documentElement.dir || 'ltr';
    const direction = 'ltr'

    const ANIMATION_CONFIG = {
        STAR_SPAWN_INTERVAL_MIN: 100,
        STAR_SPAWN_INTERVAL_MAX: 300,
        STAR_LIFETIME: 1800,
        STAR_TRAVEL_DISTANCE: 250,
        STAR_ROTATION_MAX: 180,

        WIND_LINE_SPAWN_INTERVAL_MIN: 300,
        WIND_LINE_SPAWN_INTERVAL_MAX: 600,
        WIND_LINE_TRAVEL_DURATION: 16400,
    };

    //-- ELEMENT REFERENCES
    const container = document.querySelector('.spaceship-animation-container') as HTMLElement;
    const playButton = document.querySelector('.magnet-icon') as HTMLElement;
    const starTemplate = document.querySelector('.templates .star-icon') as SVGElement;
    const lineTemplate = document.querySelector('.templates .line-icon') as SVGElement;
    
    if (container && playButton && starTemplate && lineTemplate) {
        //-- STATE MANAGEMENT
        let isAnimationActive = false;
        let starSpawnInterval = null;
        let windLineSpawnTimeout = null;

        //-- HELPER FUNCTIONS
        const getRandom = (min:number, max:number) => Math.random() * (max - min) + min;

        //-- 4. STAR LOGIC (Unchanged)
        const createAndAnimateStar = () => {
            const star = starTemplate.cloneNode(true) as SVGElement;
            container.appendChild(star);
            star.classList.add('dynamic-star');

            const buttonRect = playButton.getBoundingClientRect();
            const containerRect = container.getBoundingClientRect();
            const currentButtonY = buttonRect.top - containerRect.top + (buttonRect.height / 2);
            const spawnX = direction === 'ltr' 
                ? buttonRect.left - containerRect.left 
                : buttonRect.right - containerRect.left;
            const spawnY = currentButtonY + getRandom(-buttonRect.height / 2, buttonRect.height / 2);

            star.style.left = `${spawnX}px`;
            star.style.top = `${spawnY}px`;
            
            const travelX = direction === 'ltr' ? -ANIMATION_CONFIG.STAR_TRAVEL_DISTANCE : ANIMATION_CONFIG.STAR_TRAVEL_DISTANCE;
            const randomRotation = getRandom(-ANIMATION_CONFIG.STAR_ROTATION_MAX, ANIMATION_CONFIG.STAR_ROTATION_MAX);

            const starAnimation = star.animate([
                { transform: 'translate(-50%, -50%) scale(1) rotate(0deg)', opacity: 1 },
                { transform: `translate(${travelX}px, -50%) scale(0) rotate(${randomRotation}deg)`, opacity: 0 }
            ], {
                duration: ANIMATION_CONFIG.STAR_LIFETIME,
                easing: 'linear'
            });

            starAnimation.onfinish = () => star.remove();
        };

        //-- 5. WIND LINE LOGIC (Unchanged)
        const createAndAnimateLine = () => {
            const line = lineTemplate.cloneNode(true) as SVGElement;
            line.classList.add('dynamic-line');
            container.appendChild(line);

            const containerWidth = container.offsetWidth;
            const lineWidth = line.getBoundingClientRect().width * parseFloat(getComputedStyle(line).getPropertyValue('--line-length-multiplier'));
            
            line.style.top = `${getRandom(8, container.offsetHeight - 8)}px`;
            line.style.zIndex = `${Math.floor(getRandom(-1 ,3 ))}`

            const startX = direction === 'ltr' ? containerWidth : -lineWidth;
            const endX = direction === 'ltr' ? -lineWidth : containerWidth;

            const lineAnimation = line.animate([
                { transform: `translateX(${startX}px) translateY(-50%) scale(var(--line-length-multiplier), 1)`, opacity: 0 },
                { opacity: 1, offset: 0.1 },
                { transform: `translateX(${endX}px) translateY(-50%) scale(var(--line-length-multiplier), 1)`, opacity: 1, offset: 0.9 },
                { opacity: 0 }
            ], {
                duration: ANIMATION_CONFIG.WIND_LINE_TRAVEL_DURATION,
                iterations: 1,
                easing: 'linear'
            });
            
            lineAnimation.onfinish = () => line.remove();
        };
        
        const windLineLoop = () => {
            if (!isAnimationActive) {
                clearTimeout(windLineSpawnTimeout);
                return;
            }
            createAndAnimateLine();
            windLineSpawnTimeout = setTimeout(windLineLoop, getRandom(
                ANIMATION_CONFIG.WIND_LINE_SPAWN_INTERVAL_MIN,
                ANIMATION_CONFIG.WIND_LINE_SPAWN_INTERVAL_MAX
            ));
        };

        const startWindLinesAnimation = () => {
            windLineLoop();
        };
        
        const stopWindLinesAnimation = () => {
            clearTimeout(windLineSpawnTimeout);
        };

        //-- 2. ACTIVATION & DEACTIVATION LOGIC
        const handleActivation = () => {
            if (isAnimationActive) return;
            isAnimationActive = true;
            container.classList.add('animation-active');

            setTimeout(() => {
                if (!isAnimationActive) return;
                starSpawnInterval = setInterval(createAndAnimateStar, getRandom(ANIMATION_CONFIG.STAR_SPAWN_INTERVAL_MIN, ANIMATION_CONFIG.STAR_SPAWN_INTERVAL_MAX));
            }, 100);

            startWindLinesAnimation();
        };

        const handleDeactivation = () => {
            if (container.matches(':hover')) return;
            if (!isAnimationActive) return;

            isAnimationActive = false;
            container.classList.remove('animation-active');
            
            clearInterval(starSpawnInterval);
            stopWindLinesAnimation();
        };

        //-- 1. EVENT BINDINGS
        container.addEventListener('mouseenter', handleActivation);
        container.addEventListener('mouseleave', handleDeactivation);

        const observer = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
                if (mutation.attributeName === 'class') {
                    const target = mutation.target as HTMLElement;
                    const hasActiveClass = target.classList.contains('animation-active');
                    const wasActive = mutation.oldValue?.includes('animation-active');

                    if (hasActiveClass && !wasActive) {
                        handleActivation();
                    } else if (!hasActiveClass && wasActive) {
                        handleDeactivation();
                    }
                }
            });
        });

        observer.observe(container, { attributes: true, attributeOldValue: true });
    }

});

</script>

<style lang="less">
    // hiding
    #banner{
        transition:
      transform 0.3s ease-out,
      opacity 0.3s ease-out;
    }
    #banner.cs-hide {
    transform: translateY(-100%);
    opacity: 0;

  }
    /*-- ================================================================== -->
    <---          SPACESHIP ANIMATION STYLES
    <--- ================================================================== -*/
    .spaceship-animation-container {
      --line-length-multiplier: 5;
      --float-distance: 3px; 
      --float-duration: 2800ms;

      position: relative;
      overflow: hidden;


      .magnet-icon {
        transition: transform 0.3s ease-out, scale 0.3s ease-in-out;
        transform-origin: center;

      }
      &.animation-active .magnet-icon {

        scale: 1.2 .95;
        animation: floater var(--float-duration) ease-in-out infinite ;
        animation-delay:200ms;
      }
    }
    

    @keyframes floater {
      0%, 100% {
        transform: translateY(0)  ;
      }
      25% {
        transform: translateY(calc(-1 * var(--float-distance))) ;
      }
      75% {
        transform: translateY(var(--float-distance)) ;
      }
    }
    
    .dynamic-star, .dynamic-line {
      position: absolute;
      pointer-events: none;
      will-change: transform, opacity;
      transform-origin: center;
    }

    .dynamic-star {
      width: 16px;
      height: 16px;
      color: #ffd700;
      z-index:-1;
      transform: translate(-50%, -50%);
    }
    
    .dynamic-line {
        width: 100px; 
        height: 15px;
        color: rgba(255, 255, 255, 0.4);
        scale: var(--line-length-multiplier) 1;
        left: 0;
        opacity: 0;
    }

    /*-- -------------------------- -->
    <---          Top Banner (Original Styles)
    <--- -------------------------- -*/


    .templates{display:none; visibility: hidden; position: absolute;}

    .top-banner {
      isolation: isolate;

      background-color: #171717;
      width: 100%;
      position: fixed;
      top: 0;
      left: 0;
      z-index: 999; 


    box-shadow: 0 10px 10px rgba(0, 0, 0, 0.15);
      padding: var(--spacing-md) var(--spacing-md);
      @media (min-width:768px) {
        padding:var(--spacing-md) var(--spacing-2xl);
      }
      .top-banner-grid{
        direction: ltr;
        display:grid;
        grid-template-rows:1fr;
        grid-template-columns:1fr auto;
        align-items:center;
    
        p {
            color:white;
            z-index: 1;
            position: relative;
        }
        .magnet-title{
            font-weight: bold;
            font-size: .78rem;
        }
        .magnet-information{
            opacity:0.7;
            font-size: 1em;
            grid-row: 2;
            font-size: 0.65rem;
        }
        .magnet-icon{
          --size:24px;;
            color:var(--primaryDark);
            grid-column: 2;
            grid-row: span 2;
            display: block;
            height: var(--size);
            width:var(--size);
            align-self:center;
            z-index: 3;
            position: relative;

        }
      }
    
      @media (min-width:768px) {
        .top-banner-grid{
            display:flex;
            gap:var(--spacing-md);
            width:fit-content;
            margin:auto;
    
            .magnet-title{
                font-size: .88rem;
            }
            .magnet-information{
                font-size: .88rem;
    
                &::before{
                    content:" | "
                }
            }
            .magnet-icon{
                margin-inline-start: 40px;
            }
        }
      }
    }
</style>
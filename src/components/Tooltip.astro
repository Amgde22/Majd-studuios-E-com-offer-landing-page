---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<button
  type="button"
  class="info-icon"
  title={title}
  aria-label={title}
>
  i
</button>

<style>
  .info-icon {
    /* Base State (Identical to previous component) */
    background: #f3f4f6;
    color: #4b5563;
    border: 1px solid #d1d5db;
    border-radius: 50%;
    font-size: .85em;
    width: 1em;
    height: 1em;

    font-family: monospace;
    font-weight: 700;
    cursor: help; /* Use 'help' cursor to indicate info */
    
    /* Layout */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    line-height: 1;
    vertical-align: middle;

    /* Animation */
    transition: all 0.2s ease-in-out;
  }

  /* Hover & Focus State (Identical to previous component) */
  .info-icon:is(:hover, :focus) {
    background: #1f2937;
    color: #fff;
    border-color: #1f2937;
    outline: none; /* Optional: for a cleaner focus state */
  }
</style>
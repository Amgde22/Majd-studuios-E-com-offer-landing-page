---
import { Icon } from "astro-icon/components";
import { t } from "i18n:astro";

const data = t("home:whyUs", { returnObjects: true });
---

<section class="why-us ">
  <div class="section">
  <h2 class="title">{data.title}</h2>
  <div class="features">
    {
      data.features.map((feature) => (
        <div class="feature">
          <div class="icon-container">
            <Icon class="checkmark" name="checkmark-swirly" />
          </div>
          <h3 class="heading">
            <Icon class="caret" name="mdi--caret" />
            {feature.title}

          </h3>
          <div class="dotted-line-container">
            <div class="dotted-line"></div>
          </div>
          <div class="body" >
            <div set:html={feature.description}></div>
          </div>
        </div>
      ))
    }
  </div>
</div>
</section>
<style lang="less" scoped>
    @electric-blue: #007BFF;
    @checkmark-size: 35px;

    .why-us {
      background-color: #f9fafb;
    }
    .title{
      font-size: calc(26px + (8) * (100vw - 340px) / (1024 - 400));
      margin-bottom:1.8em;
      color: #040A29;

    }

  
    .features {
      display: grid;
      gap: 2rem;
  
      @media (min-width: 768px) {
        grid-template-columns: repeat(2, 1fr);
        justify-content: space-evenly;
      }
    }
  
    .feature {
      display: grid;
      grid-template-columns: auto 1fr;
      grid-template-rows: min-content 1fr;
      gap: 0.5rem 1rem;
      max-width:500px;
      cursor: pointer;
  
      &.active {
          
        .heading {
          opacity:1;
        }
        .caret{
          rotate: 0deg;
        }
        .body {
          max-height: 20rem; 
          color: var(--gray-600);
          &::after {
            opacity: 0;
          }
        }
        .dotted-line {
            height: 100%;
        }
        .checkmark {
            background-color: @electric-blue;
            color: white;
            border-radius: 100%;
            padding: 2px;
        }
      }
    }
  
    .icon-container {
      grid-row: 1;
      align-self: center;

      .checkmark{
        display: block;
        width: @checkmark-size;
        height: @checkmark-size;
        color: @electric-blue;
        background-color: transparent;
        padding: 0;
        border-radius: 0;
        transition: background-color 0.3s ease-in-out, color 0.3s ease-in-out, border-radius 0.3s ease-in-out, padding 0.3s ease-in-out;
      }
    }
  
    .heading {
      font-size: calc(24px + (4) * (100vw - 340px) / (1024 - 400));
      color: #040A29;
      opacity:0.6;
      grid-row: 1;
      align-self: center;

      .caret{
        transition:rotate 120ms;
        translate: 0;
        scale: 1.2;
        rotate: 180deg;
        display:inline;

      }
    }
  
    .dotted-line-container {
        grid-row: 2;
        position: relative;
        width: 2px;
        justify-self: center;

        .dotted-line {
            height: 3.5em;
            width: 100%;
            background-image: repeating-linear-gradient(to bottom, var(--gray-400, #9ca3af) 0, var(--gray-400, #9ca3af) 5px, transparent 5px, transparent 10px);
            transition: height 0.3s ease-in-out;
        }
    }
  
    .body {
      grid-column: 2;
      grid-row: 2;
      max-height: 3.5em; 
      position: relative;
      cursor: pointer;
      transition: max-height 0.3s ease-in-out, color 0.3s ease-in-out;
      overflow:hidden;
      color: var(--gray-400);
      font-size: 1.05em;

      &::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 1.5em;
        background: linear-gradient(to bottom, transparent, #f9fafb);
        transition: opacity 0.3s ease-in-out;
      }
    }
</style>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const features = document.querySelectorAll('.feature');
    features.forEach(feature => {
      const body = feature.querySelector('.body');
      if (feature) {
        feature.addEventListener('click', () => {
          feature.classList.toggle('active');
        });
      }
    });
  });
</script>
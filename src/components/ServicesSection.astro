---
import { t } from "i18n:astro";
import IndividualServiceCard from "./TemplateComponents/IndividualServiceCard.astro";

const services = t("home:individualServices", { returnObjects: true });
---

<section id="individual-services" class="py-24 px-4 bg-gray-50">
  <div class="max-w-[1200px] mx-auto">
    <h2 class="text-2xl md:text-3xl font-black text-gray-900 mb-12 text-center uppercase tracking-tight">
      {services.heading}
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-8 justify-items-center">
      {services.items.map((service: any) => (
        <IndividualServiceCard {...service} />
      ))}
    </div>
  </div>
</section>

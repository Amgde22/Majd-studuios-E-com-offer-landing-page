  position: absolute;
  left: 75%;
  bottom: 0; 
  width: 75%; 
  height: 80%;
  border-radius: 50%;
  transform-origin:left;
  transform: translateX(-50%) scaleX(1);
  rotate: 15deg;
  z-index: -1;
}
.shadow-img{
  width: 100%;
  height: 100%;
  scale: 1.5;
  opacity:.5;
}

:global([dir="rtl"]) #model-container {
  transform-origin: top right;
  
}
</style>